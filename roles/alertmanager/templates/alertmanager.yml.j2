---
global:
  smtp_smarthost: '{{ alertmanager_smtp_host }}'
  smtp_from: '{{ alertmanager_smtp_from }}'
  smtp_require_tls: true
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'job', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: ops-email

  routes:
    - match:
        severity: critical
      receiver: ops-email
      repeat_interval: 1h

    - match:
        severity: warning
      receiver: ops-email
      repeat_interval: 4h

receivers:
  - name: ops-email
    email_configs:
      - to: '{{ alertmanager_receiver_email }}'
        send_resolved: true
        headers:
          Subject: '[{{ "{{" }} .Status | toUpper {{ "}}" }}] {{ "{{" }} .GroupLabels.alertname {{ "}}" }}'

inhibit_rules:
  # Suppress warning-severity alerts when a critical alert fires for the same instance
  - source_match:
      severity: critical
    target_match:
      severity: warning
    equal: ['instance', 'job']
