---
global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}
  # external_labels differentiate this node's TSDB data in Grafana and Thanos.
  # NOTE: do NOT include these labels in alert rule expressions — they are
  # stripped by Alertmanager fingerprinting so deduplication works correctly.
  external_labels:
    monitor: '{{ inventory_hostname }}'
    replica: '{{ prometheus_replica_label }}'

alerting:
  alertmanagers:
    - static_configs:
        - targets:
{% for host in groups['monitoring'] %}
            - '{{ hostvars[host].ansible_host }}:9093'
{% endfor %}

rule_files:
  - '{{ prometheus_config_dir }}/rules/*.yml'

scrape_configs:

  # Prometheus scrapes itself
  - job_name: prometheus
    scrape_interval: 15s
    static_configs:
      - targets:
          - 'localhost:9090'

  # Node Exporter — per-host options are read from inventory/host_vars/<host>.yml.
{% if groups['linux_nodes'] | length > 0 %}
{% for host in groups['linux_nodes'] %}
  - job_name: '{{ hostvars[host].node_exporter_job_name | default("node_" ~ host) }}'
    scrape_interval: {{ hostvars[host].node_exporter_scrape_interval | default(prometheus_scrape_interval) }}
{% if hostvars[host].node_exporter_scrape_timeout is defined %}
    scrape_timeout: {{ hostvars[host].node_exporter_scrape_timeout }}
{% endif %}
    scheme: {{ hostvars[host].node_exporter_scheme | default('http') }}
    metrics_path: {{ hostvars[host].node_exporter_metrics_path | default('/metrics') }}
    static_configs:
      - targets:
          - '{{ hostvars[host].node_exporter_target | default(hostvars[host].ansible_host ~ ":" ~ (hostvars[host].node_exporter_port | default(node_exporter_port))) }}'
        labels:
          hostname: '{{ host }}'
{% if hostvars[host].prometheus_labels is defined %}
{% for key, value in hostvars[host].prometheus_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% if hostvars[host].node_exporter_labels is defined %}
{% for key, value in hostvars[host].node_exporter_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

  # PostgreSQL exporter — per-host options are read from inventory/host_vars/<host>.yml.
{% if groups['postgres_servers'] | length > 0 %}
{% for host in groups['postgres_servers'] %}
  - job_name: '{{ hostvars[host].postgres_exporter_job_name | default("postgres_" ~ host) }}'
    scrape_interval: {{ hostvars[host].postgres_exporter_scrape_interval | default(prometheus_scrape_interval) }}
{% if hostvars[host].postgres_exporter_scrape_timeout is defined %}
    scrape_timeout: {{ hostvars[host].postgres_exporter_scrape_timeout }}
{% endif %}
    scheme: {{ hostvars[host].postgres_exporter_scheme | default('http') }}
    metrics_path: {{ hostvars[host].postgres_exporter_metrics_path | default('/metrics') }}
    static_configs:
      - targets:
          - '{{ hostvars[host].postgres_exporter_target | default(hostvars[host].ansible_host ~ ":" ~ (hostvars[host].postgres_exporter_port | default(postgres_exporter_port))) }}'
        labels:
          hostname: '{{ host }}'
{% if hostvars[host].prometheus_labels is defined %}
{% for key, value in hostvars[host].prometheus_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% if hostvars[host].postgres_exporter_labels is defined %}
{% for key, value in hostvars[host].postgres_exporter_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

  # Custom services — exporters already exist on these hosts.
  # Per-host options are read from inventory/host_vars/<host>.yml.
{% if groups['custom_service'] is defined and groups['custom_service'] | length > 0 %}
{% for host in groups['custom_service'] %}
  - job_name: '{{ hostvars[host].custom_service_job_name | default("custom_service_" ~ host) }}'
    scrape_interval: {{ hostvars[host].custom_service_scrape_interval | default(prometheus_scrape_interval) }}
{% if hostvars[host].custom_service_scrape_timeout is defined %}
    scrape_timeout: {{ hostvars[host].custom_service_scrape_timeout }}
{% endif %}
    scheme: {{ hostvars[host].custom_service_scheme | default('http') }}
    metrics_path: {{ hostvars[host].custom_service_metrics_path | default('/metrics') }}
{% if hostvars[host].custom_service_params is defined %}
    params:
{% for key, value in hostvars[host].custom_service_params.items() %}
      {{ key }}: {{ value | to_json }}
{% endfor %}
{% endif %}
{% if hostvars[host].custom_service_basic_auth_username is defined and hostvars[host].custom_service_basic_auth_password is defined %}
    basic_auth:
      username: '{{ hostvars[host].custom_service_basic_auth_username }}'
      password: '{{ hostvars[host].custom_service_basic_auth_password }}'
{% endif %}
{% if hostvars[host].custom_service_bearer_token is defined %}
    bearer_token: '{{ hostvars[host].custom_service_bearer_token }}'
{% endif %}
{% if hostvars[host].custom_service_tls_insecure_skip_verify is defined or hostvars[host].custom_service_tls_ca_file is defined or hostvars[host].custom_service_tls_cert_file is defined or hostvars[host].custom_service_tls_key_file is defined %}
    tls_config:
{% if hostvars[host].custom_service_tls_insecure_skip_verify is defined %}
      insecure_skip_verify: {{ hostvars[host].custom_service_tls_insecure_skip_verify | bool | lower }}
{% endif %}
{% if hostvars[host].custom_service_tls_ca_file is defined %}
      ca_file: '{{ hostvars[host].custom_service_tls_ca_file }}'
{% endif %}
{% if hostvars[host].custom_service_tls_cert_file is defined %}
      cert_file: '{{ hostvars[host].custom_service_tls_cert_file }}'
{% endif %}
{% if hostvars[host].custom_service_tls_key_file is defined %}
      key_file: '{{ hostvars[host].custom_service_tls_key_file }}'
{% endif %}
{% endif %}
    static_configs:
      - targets:
          - '{{ hostvars[host].custom_service_target | default(hostvars[host].ansible_host ~ ":" ~ (hostvars[host].custom_service_port | default(9100))) }}'
        labels:
          hostname: '{{ host }}'
{% if hostvars[host].prometheus_labels is defined %}
{% for key, value in hostvars[host].prometheus_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% if hostvars[host].custom_service_labels is defined %}
{% for key, value in hostvars[host].custom_service_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

  # Proxmox VE — per-node options are read from inventory/host_vars/<host>.yml.
{% if groups['proxmox_nodes'] | length > 0 %}
{% for host in groups['proxmox_nodes'] %}
  - job_name: '{{ hostvars[host].proxmox_job_name | default("proxmox_" ~ host) }}'
    scrape_interval: {{ hostvars[host].proxmox_scrape_interval | default(prometheus_scrape_interval) }}
{% if hostvars[host].proxmox_scrape_timeout is defined %}
    scrape_timeout: {{ hostvars[host].proxmox_scrape_timeout }}
{% endif %}
    metrics_path: {{ hostvars[host].proxmox_metrics_path | default('/pve') }}
    params:
      module: ['{{ hostvars[host].proxmox_module_name | default("default") }}']
      cluster: ['{{ hostvars[host].proxmox_cluster | default("1") }}']
      node: ['{{ hostvars[host].proxmox_node | default("1") }}']
    static_configs:
      - targets:
          - '{{ hostvars[host].ansible_host }}'
        labels:
          hostname: '{{ host }}'
{% if hostvars[host].prometheus_labels is defined %}
{% for key, value in hostvars[host].prometheus_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% if hostvars[host].proxmox_labels is defined %}
{% for key, value in hostvars[host].proxmox_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 'localhost:{{ proxmox_exporter_port }}'
{% endfor %}
{% endif %}

  # MAAS region controller — per-host options are read from inventory/host_vars/<host>.yml.
{% if groups['maas_controllers'] | length > 0 %}
{% for host in groups['maas_controllers'] %}
  - job_name: '{{ hostvars[host].maas_job_name | default("maas_" ~ host) }}'
    scrape_interval: {{ hostvars[host].maas_scrape_interval | default(prometheus_scrape_interval) }}
{% if hostvars[host].maas_scrape_timeout is defined %}
    scrape_timeout: {{ hostvars[host].maas_scrape_timeout }}
{% endif %}
    scheme: {{ hostvars[host].maas_scheme | default('http') }}
    metrics_path: {{ hostvars[host].maas_metrics_path | default('/MAAS/metrics') }}
    static_configs:
      - targets:
          - '{{ hostvars[host].maas_target | default(hostvars[host].ansible_host ~ ":" ~ (hostvars[host].maas_port | default(5240))) }}'
        labels:
          hostname: '{{ host }}'
{% if hostvars[host].prometheus_labels is defined %}
{% for key, value in hostvars[host].prometheus_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% if hostvars[host].maas_labels is defined %}
{% for key, value in hostvars[host].maas_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

  # SNMP switches via snmp_exporter.
  # Per-switch scrape options are read from inventory/host_vars/<host>.yml.
{% if groups['snmp_switches'] is defined and groups['snmp_switches'] | length > 0 %}
{% for host in groups['snmp_switches'] %}
  - job_name: '{{ hostvars[host].snmp_job_name | default("snmp_" ~ host) }}'
    scrape_interval: {{ hostvars[host].snmp_scrape_interval | default(snmp_scrape_interval) }}
    scrape_timeout: {{ hostvars[host].snmp_scrape_timeout | default(snmp_scrape_timeout) }}
    metrics_path: /snmp
    params:
      module: ['{{ hostvars[host].snmp_module_name | default(snmp_module_name) }}']
      auth: ['{{ hostvars[host].snmp_auth_name | default("v2_public") }}']
    static_configs:
      - targets:
          - '{{ hostvars[host].ansible_host }}'
        labels:
          hostname: '{{ host }}'
{% if hostvars[host].prometheus_labels is defined %}
{% for key, value in hostvars[host].prometheus_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% if hostvars[host].snmp_labels is defined %}
{% for key, value in hostvars[host].snmp_labels.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 'localhost:{{ snmp_exporter_port }}'
{% endfor %}
{% endif %}

  # Alertmanager self-monitoring
  - job_name: alertmanager
    scrape_interval: 15s
    static_configs:
      - targets:
{% for host in groups['monitoring'] %}
          - '{{ hostvars[host].ansible_host }}:9093'
{% endfor %}

  # Grafana self-monitoring
  - job_name: grafana
    scrape_interval: 30s
    static_configs:
      - targets:
{% for host in groups['monitoring'] %}
          - '{{ hostvars[host].ansible_host }}:{{ grafana_port }}'
{% endfor %}
