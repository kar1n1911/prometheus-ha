---
global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}
  # external_labels differentiate this node's TSDB data in Grafana and Thanos.
  # NOTE: do NOT include these labels in alert rule expressions — they are
  # stripped by Alertmanager fingerprinting so deduplication works correctly.
  external_labels:
    monitor: '{{ inventory_hostname }}'
    replica: '{{ prometheus_replica_label }}'

alerting:
  alertmanagers:
    - static_configs:
        - targets:
{% for host in groups['monitoring'] %}
            - '{{ hostvars[host].ansible_host }}:9093'
{% endfor %}

rule_files:
  - '{{ prometheus_config_dir }}/rules/*.yml'

scrape_configs:

  # Prometheus scrapes itself
  - job_name: prometheus
    scrape_interval: 15s
    static_configs:
      - targets:
          - 'localhost:9090'

  # Node Exporter — per-host options are read from inventory/host_vars/<host>.yml.
{% if groups['linux_nodes'] %}
{% for host in groups['linux_nodes'] %}
{% set h = hostvars[host] %}
  - job_name: '{{ h.node_exporter_job_name | default("node_" ~ host) }}'
    scrape_interval: {{ h.node_exporter_scrape_interval | default(prometheus_scrape_interval) }}
{% if h.node_exporter_scrape_timeout is defined %}
    scrape_timeout: {{ h.node_exporter_scrape_timeout }}
{% endif %}
    scheme: {{ h.node_exporter_scheme | default('http') }}
    metrics_path: {{ h.node_exporter_metrics_path | default('/metrics') }}
{% if h.node_exporter_bearer_token is defined %}
    bearer_token: '{{ h.node_exporter_bearer_token }}'
{% elif h.node_exporter_basic_auth_username is defined and h.node_exporter_basic_auth_password is defined %}
    basic_auth:
      username: '{{ h.node_exporter_basic_auth_username }}'
      password: '{{ h.node_exporter_basic_auth_password }}'
{% endif %}
{% if h.node_exporter_tls_insecure_skip_verify is defined or h.node_exporter_tls_ca_file is defined or (h.node_exporter_tls_cert_file is defined and h.node_exporter_tls_key_file is defined) %}
    tls_config:
{% if h.node_exporter_tls_insecure_skip_verify is defined %}
      insecure_skip_verify: {{ h.node_exporter_tls_insecure_skip_verify | bool | lower }}
{% endif %}
{% if h.node_exporter_tls_ca_file is defined %}
      ca_file: '{{ h.node_exporter_tls_ca_file }}'
{% endif %}
{% if h.node_exporter_tls_cert_file is defined and h.node_exporter_tls_key_file is defined %}
      cert_file: '{{ h.node_exporter_tls_cert_file }}'
      key_file: '{{ h.node_exporter_tls_key_file }}'
{% endif %}
{% endif %}
    static_configs:
      - targets:
          - '{{ h.node_exporter_target | default(h.ansible_host ~ ":" ~ (h.node_exporter_port | default(node_exporter_port))) }}'
        labels:
          hostname: '{{ host }}'
{% for key, value in (h.prometheus_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% for key, value in (h.node_exporter_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endfor %}
{% endif %}

  # PostgreSQL exporter — per-host options are read from inventory/host_vars/<host>.yml.
{% if groups['postgres_servers'] %}
{% for host in groups['postgres_servers'] %}
{% set h = hostvars[host] %}
  - job_name: '{{ h.postgres_exporter_job_name | default("postgres_" ~ host) }}'
    scrape_interval: {{ h.postgres_exporter_scrape_interval | default(prometheus_scrape_interval) }}
{% if h.postgres_exporter_scrape_timeout is defined %}
    scrape_timeout: {{ h.postgres_exporter_scrape_timeout }}
{% endif %}
    scheme: {{ h.postgres_exporter_scheme | default('http') }}
    metrics_path: {{ h.postgres_exporter_metrics_path | default('/metrics') }}
{% if h.postgres_exporter_bearer_token is defined %}
    bearer_token: '{{ h.postgres_exporter_bearer_token }}'
{% elif h.postgres_exporter_basic_auth_username is defined and h.postgres_exporter_basic_auth_password is defined %}
    basic_auth:
      username: '{{ h.postgres_exporter_basic_auth_username }}'
      password: '{{ h.postgres_exporter_basic_auth_password }}'
{% endif %}
{% if h.postgres_exporter_tls_insecure_skip_verify is defined or h.postgres_exporter_tls_ca_file is defined or (h.postgres_exporter_tls_cert_file is defined and h.postgres_exporter_tls_key_file is defined) %}
    tls_config:
{% if h.postgres_exporter_tls_insecure_skip_verify is defined %}
      insecure_skip_verify: {{ h.postgres_exporter_tls_insecure_skip_verify | bool | lower }}
{% endif %}
{% if h.postgres_exporter_tls_ca_file is defined %}
      ca_file: '{{ h.postgres_exporter_tls_ca_file }}'
{% endif %}
{% if h.postgres_exporter_tls_cert_file is defined and h.postgres_exporter_tls_key_file is defined %}
      cert_file: '{{ h.postgres_exporter_tls_cert_file }}'
      key_file: '{{ h.postgres_exporter_tls_key_file }}'
{% endif %}
{% endif %}
    static_configs:
      - targets:
          - '{{ h.postgres_exporter_target | default(h.ansible_host ~ ":" ~ (h.postgres_exporter_port | default(postgres_exporter_port))) }}'
        labels:
          hostname: '{{ host }}'
{% for key, value in (h.prometheus_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% for key, value in (h.postgres_exporter_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endfor %}
{% endif %}

  # Custom services — exporters already exist on these hosts.
  # Per-host options are read from inventory/host_vars/<host>.yml.
{% if groups['custom_service'] is defined and groups['custom_service'] %}
{% for host in groups['custom_service'] %}
{% set h = hostvars[host] %}
  - job_name: '{{ h.custom_service_job_name | default("custom_service_" ~ host) }}'
    scrape_interval: {{ h.custom_service_scrape_interval | default(prometheus_scrape_interval) }}
{% if h.custom_service_scrape_timeout is defined %}
    scrape_timeout: {{ h.custom_service_scrape_timeout }}
{% endif %}
    scheme: {{ h.custom_service_scheme | default('http') }}
    metrics_path: {{ h.custom_service_metrics_path | default('/metrics') }}
{% if h.custom_service_params is defined %}
    params:
{% for key, value in h.custom_service_params.items() %}
      {{ key }}: {{ value | to_json }}
{% endfor %}
{% endif %}
{% if h.custom_service_bearer_token is defined %}
    bearer_token: '{{ h.custom_service_bearer_token }}'
{% elif h.custom_service_basic_auth_username is defined and h.custom_service_basic_auth_password is defined %}
    basic_auth:
      username: '{{ h.custom_service_basic_auth_username }}'
      password: '{{ h.custom_service_basic_auth_password }}'
{% endif %}
{% if h.custom_service_tls_insecure_skip_verify is defined or h.custom_service_tls_ca_file is defined or (h.custom_service_tls_cert_file is defined and h.custom_service_tls_key_file is defined) %}
    tls_config:
{% if h.custom_service_tls_insecure_skip_verify is defined %}
      insecure_skip_verify: {{ h.custom_service_tls_insecure_skip_verify | bool | lower }}
{% endif %}
{% if h.custom_service_tls_ca_file is defined %}
      ca_file: '{{ h.custom_service_tls_ca_file }}'
{% endif %}
{% if h.custom_service_tls_cert_file is defined and h.custom_service_tls_key_file is defined %}
      cert_file: '{{ h.custom_service_tls_cert_file }}'
      key_file: '{{ h.custom_service_tls_key_file }}'
{% endif %}
{% endif %}
    static_configs:
      - targets:
          - '{{ h.custom_service_target | default(h.ansible_host ~ ":" ~ (h.custom_service_port | default(9100))) }}'
        labels:
          hostname: '{{ host }}'
{% for key, value in (h.prometheus_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% for key, value in (h.custom_service_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endfor %}
{% endif %}

  # Proxmox VE — per-node options are read from inventory/host_vars/<host>.yml.
{% if groups['proxmox_nodes'] %}
{% for host in groups['proxmox_nodes'] %}
{% set h = hostvars[host] %}
  - job_name: '{{ h.proxmox_job_name | default("proxmox_" ~ host) }}'
    scrape_interval: {{ h.proxmox_scrape_interval | default(prometheus_scrape_interval) }}
{% if h.proxmox_scrape_timeout is defined %}
    scrape_timeout: {{ h.proxmox_scrape_timeout }}
{% endif %}
    metrics_path: {{ h.proxmox_metrics_path | default('/pve') }}
    params:
      module: ['{{ h.proxmox_module_name | default("default") }}']
      cluster: ['{{ h.proxmox_cluster | default("1") }}']
      node: ['{{ h.proxmox_node | default("1") }}']
    static_configs:
      - targets:
          - '{{ h.ansible_host }}'
        labels:
          hostname: '{{ host }}'
{% for key, value in (h.prometheus_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% for key, value in (h.proxmox_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 'localhost:{{ proxmox_exporter_port }}'
{% endfor %}
{% endif %}

  # MAAS region controller — per-host options are read from inventory/host_vars/<host>.yml.
{% if groups['maas_controllers'] %}
{% for host in groups['maas_controllers'] %}
{% set h = hostvars[host] %}
  - job_name: '{{ h.maas_job_name | default("maas_" ~ host) }}'
    scrape_interval: {{ h.maas_scrape_interval | default(prometheus_scrape_interval) }}
{% if h.maas_scrape_timeout is defined %}
    scrape_timeout: {{ h.maas_scrape_timeout }}
{% endif %}
    scheme: {{ h.maas_scheme | default('http') }}
    metrics_path: {{ h.maas_metrics_path | default('/snmp') }}
    params:
      module: ['{{ h.maas_snmp_module | default("if_mib") }}']
{% if h.maas_bearer_token is defined %}
    bearer_token: '{{ h.maas_bearer_token }}'
{% elif h.maas_basic_auth_username is defined and h.maas_basic_auth_password is defined %}
    basic_auth:
      username: '{{ h.maas_basic_auth_username }}'
      password: '{{ h.maas_basic_auth_password }}'
{% endif %}
{% if h.maas_tls_insecure_skip_verify is defined or h.maas_tls_ca_file is defined or (h.maas_tls_cert_file is defined and h.maas_tls_key_file is defined) %}
    tls_config:
{% if h.maas_tls_insecure_skip_verify is defined %}
      insecure_skip_verify: {{ h.maas_tls_insecure_skip_verify | bool | lower }}
{% endif %}
{% if h.maas_tls_ca_file is defined %}
      ca_file: '{{ h.maas_tls_ca_file }}'
{% endif %}
{% if h.maas_tls_cert_file is defined and h.maas_tls_key_file is defined %}
      cert_file: '{{ h.maas_tls_cert_file }}'
      key_file: '{{ h.maas_tls_key_file }}'
{% endif %}
{% endif %}
    static_configs:
      - targets:
          - "{{ h.maas_target | default(h.ansible_host) }}:{{ h.maas_port | default('5240') }}"
        labels:
          hostname: '{{ host }}'
{% for key, value in (h.prometheus_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% for key, value in (h.maas_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endfor %}
{% endif %}

  # SNMP switches via snmp_exporter.
  # Per-switch scrape options are read from inventory/host_vars/<host>.yml.
{% if groups['snmp_switches'] is defined and groups['snmp_switches'] %}
{% for host in groups['snmp_switches'] %}
{% set h = hostvars[host] %}
  - job_name: '{{ h.snmp_job_name | default("snmp_" ~ host) }}'
    scrape_interval: {{ h.snmp_scrape_interval | default(snmp_scrape_interval) }}
    scrape_timeout: {{ h.snmp_scrape_timeout | default(snmp_scrape_timeout) }}
    metrics_path: /snmp
{% if h.snmp_bearer_token is defined %}
    bearer_token: '{{ h.snmp_bearer_token }}'
{% elif h.snmp_basic_auth_username is defined and h.snmp_basic_auth_password is defined %}
    basic_auth:
      username: '{{ h.snmp_basic_auth_username }}'
      password: '{{ h.snmp_basic_auth_password }}'
{% endif %}
{% if h.snmp_tls_insecure_skip_verify is defined or h.snmp_tls_ca_file is defined or (h.snmp_tls_cert_file is defined and h.snmp_tls_key_file is defined) %}
    tls_config:
{% if h.snmp_tls_insecure_skip_verify is defined %}
      insecure_skip_verify: {{ h.snmp_tls_insecure_skip_verify | bool | lower }}
{% endif %}
{% if h.snmp_tls_ca_file is defined %}
      ca_file: '{{ h.snmp_tls_ca_file }}'
{% endif %}
{% if h.snmp_tls_cert_file is defined and h.snmp_tls_key_file is defined %}
      cert_file: '{{ h.snmp_tls_cert_file }}'
      key_file: '{{ h.snmp_tls_key_file }}'
{% endif %}
{% endif %}
    params:
      module: ['{{ h.snmp_module_name | default(snmp_module_name) }}']
      auth: ['{{ h.snmp_auth_name | default("v2_public") }}']
    static_configs:
      - targets:
          - '{{ h.ansible_host }}'
        labels:
          hostname: '{{ host }}'
{% for key, value in (h.prometheus_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% for key, value in (h.snmp_labels | default({})).items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 'localhost:{{ snmp_exporter_port }}'
{% endfor %}
{% endif %}

  # Alertmanager self-monitoring
  - job_name: alertmanager
    scrape_interval: 15s
    static_configs:
      - targets:
{% for host in groups['monitoring'] %}
          - '{{ hostvars[host].ansible_host }}:9093'
{% endfor %}

  # Grafana self-monitoring
  - job_name: grafana
    scrape_interval: 30s
    static_configs:
      - targets:
{% for host in groups['monitoring'] %}
          - '{{ hostvars[host].ansible_host }}:{{ grafana_port }}'
{% endfor %}
