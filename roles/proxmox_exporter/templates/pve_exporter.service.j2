[Unit]
Description=Prometheus Proxmox VE Exporter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pve_exporter
Group=pve_exporter
ExecStart=/opt/pve_exporter/venv/bin/pve_exporter \
  --config.file /etc/pve_exporter/pve.yml \
  --web.listen-address 0.0.0.0:{{ proxmox_exporter_port }}
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
