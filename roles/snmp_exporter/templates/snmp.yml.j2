---
auths:
  v2_public:
    community: "{{ snmp_v2_community }}"
    version: 2

  v3_default:
    username: "{{ snmp_v3_username }}"
    auth_password: "{{ snmp_v3_auth_password }}"
    auth_protocol: "{{ snmp_v3_auth_protocol }}"
    priv_protocol: "{{ snmp_v3_priv_protocol }}"
    priv_password: "{{ snmp_v3_priv_password }}"
    security_level: authPriv
    version: 3

{% for host in groups['snmp_switches'] %}
  {%- set h = hostvars[host] -%}
  {%- if h.snmp_v2_community is defined %}
  {{ h.snmp_auth_name }}:
    version: 2
    community: "{{ h.snmp_v2_community }}"
  {%- else %}
  {{ h.snmp_auth_name }}:
    version: 3
    username: "{{ h.snmp_v3_username }}"
    security_level: authPriv
    auth_protocol: "{{ h.snmp_v3_auth_protocol }}"
    auth_password: "{{ h.snmp_v3_auth_password }}"
    priv_protocol: "{{ h.snmp_v3_priv_protocol }}"
    priv_password: "{{ h.snmp_v3_priv_password }}"
  {%- endif %}
{% endfor %}


modules:
  if_mib:
    walk:
      - 1.3.6.1.2.1.1.3
      - 1.3.6.1.2.1.2.1
      - 1.3.6.1.2.1.2.2.1.2
      - 1.3.6.1.2.1.2.2.1.8
      - 1.3.6.1.2.1.31.1.1.1.1
      - 1.3.6.1.2.1.31.1.1.1.6
      - 1.3.6.1.2.1.31.1.1.1.10
    metrics:
      - name: ifDescr
        oid: 1.3.6.1.2.1.2.2.1.2
        type: DisplayString
        help: Interface description
        indexes:
          - labelname: ifIndex
            type: gauge
      - name: ifOperStatus
        oid: 1.3.6.1.2.1.2.2.1.8
        type: gauge
        help: Interface operational status
        indexes:
          - labelname: ifIndex
            type: gauge
